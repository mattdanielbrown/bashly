---
patterns:
- cli [root options]
- cli download|d [download options] <source> <target>
- cli upload|u [upload options] <source>
options:
  root:
  - "--help|-h"
  - "--version|-v"
  download:
  - "--help|-h"
  - "--force|-f"
  upload:
  - "--help|-h"
  - "--user|-u <user>"
  - "--password|-p <password>"
tokens:
  source:
  target:
  user:
  password:
