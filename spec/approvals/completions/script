  fi

  if (( ${#non_options[@]} >= 1 )) &&
    (( 1 > route_word_count )) &&
    [[ "${non_options[0]}" == "goodbye" ]]
  then
    route_id=3
    route_word_count=1
    route_has_positionals=0
    positional_index=$((${#non_options[@]} - 1))
  fi

  if (( ${#non_options[@]} >= 2 )) &&
    (( 2 > route_word_count )) &&
    [[ "${non_options[0]}" == "goodbye" ]] &&
    [[ "${non_options[1]}" == "universe" ]]
  then
    route_id=4
    route_word_count=2
    route_has_positionals=0
    positional_index=$((${#non_options[@]} - 2))
  fi

}

