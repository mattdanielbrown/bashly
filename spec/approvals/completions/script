    (( 1 > route_word_count )) &&
    [[ "${non_options[0]}" == "hello" ]]
  then
    route_id=1
    route_word_count=1
    route_has_positionals=0
    positional_index=$((${#non_options[@]} - 1))
  fi

  if (( ${#non_options[@]} >= 2 )) &&
    (( 2 > route_word_count )) &&
    [[ "${non_options[0]}" == "hello" ]] &&
    [[ "${non_options[1]}" == "world" ]]
  then
    route_id=2
    route_word_count=2
    route_has_positionals=0
